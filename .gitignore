*~
__pycache__
.idea/
.vscode/
.DS_Store
.ipynb_checkpoints/
/config/
data/
images/sound*
.venv/
test-code/
.python-version

# Case-insensitive match for files or directories named exactly "temp"
# (e.g. lib_shared/TEMP, foo/temp/, foo/temp). Does NOT match template.py,
# temperature.py, tempfile*, etc. — the pattern is exact 4-char basename.
# Tracked files like heart-message-manager/temp are unaffected (gitignore
# never overrides tracking; clean those up separately if desired).
[Tt][Ee][Mm][Pp]

# Operator local-dev overrides. The folder is tracked in git (via a
# `.gitkeep` placeholder) so the override mechanism is discoverable on
# a fresh clone; the contents are gitignored so operators can drop
# `effects_settings.json`, `config.json`, `seed_messages.json` here
# without committing them. See openspec/changes/effects-override/design.md D1.
config_overrides/*
!config_overrides/.gitkeep

settings.toml

secret_key
db.sqlite

# Agent Orchestrator runtime state
.ao/
.git_wt_initialized
.settings_copy.log

# Worktree-local AO hooks (re-run scripts/install_ao_hooks.sh to install)
.claude/settings.json
.claude/activity-updater.sh
.claude/metadata-updater.sh
