# Wi-Fi is managed by the Raspberry Pi OS (nmcli / raspi-config), not this
# process — no WIFI_SSID / WIFI_PASSWORD needed here.

# Adafruit IO over MQTT.
# MQTT_HOST Default: io.adafruit.com (Adafruit IO cloud with TLS on port 8883).
#   Local dev with Mosquitto: localhost, port 1883 (no TLS).
# MQTT_USERNAME = your AIO username, MQTT_PASSWORD = your AIO key.
# MQTT_TOPIC is the full wire-format topic — paho subscribes verbatim, with
# no broker-specific translation. For Adafruit IO, that means
# "{username}/feeds/{feedname}" (e.g. "mbustosorg/feeds/lindsay50"). For
# local Mosquitto, any topic works (e.g. "lindsay50" or "test/configs").
# This value must match the Flask server's MQTT_TOPIC so the Pi and the
# server subscribe to the same feed.
MQTT_HOST = "io.adafruit.com"
MQTT_PORT = 1883
MQTT_USERNAME = "YOUR_AIO_USERNAME"
MQTT_PASSWORD = "YOUR_AIO_KEY"
MQTT_TOPIC = "YOUR_AIO_USERNAME/feeds/YOUR_AIO_FEED_NAME"

# Status topic — the Pi publishes its health snapshot (schema_version,
# active_sha, short_sha, started_at, updated_at, uptime_seconds,
# mqtt_connected, last_error) to this topic every 5s. The Flask
# server subscribes to it and forwards updates to the browser.
# Empty = derive as "{MQTT_TOPIC}-status" (e.g.
# "mbustosorg/feeds/lindsay50-status"). On Adafruit IO the
# corresponding feed must be created in the AIO dashboard
# before the first publish — the broker silently rejects
# publishes to a non-existent feed. The env var
# `MQTT_STATUS_TOPIC` (if set) takes precedence over this
# value at process start.
MQTT_STATUS_TOPIC = ""

# Flask server REST API URLs for seeding config and messages on boot.
# The ESP32 boots without persistent storage, so it seeds from the Flask server.
MESSAGES_API_URL = "http://YOUR_FLASK_HOST/api/messages"
CONFIG_API_URL = "http://YOUR_FLASK_HOST/api/config"

# Origin of the Flask server's media proxy endpoint. The MediaCycler
# (per-message background effect for MMS attachments) fetches each
# attachment via "{MEDIA_API_BASE_URL}/api/media/{s3_key}", which the
# Flask server 302-redirects to a signed S3 URL. Defaults to the
# MESSAGES_API_URL origin (same Flask host) with no trailing path.
# The env var MEDIA_API_BASE_URL (if set) takes precedence over this
# value at process start.
MEDIA_API_BASE_URL = "http://YOUR_FLASK_HOST"

# BDF font for scrolling text. The repo ships two vendored options
# (both public-domain Markus Kuhn fonts from the hzeller
# rpi-rgb-led-matrix repo):
#   fonts/8x13.bdf — 13 px tall, the default (more readable on long lines)
#   fonts/6x9.bdf  — 9 px tall, smaller / denser text
# Point FONT_PATH at either one, or any BDF font you copy onto the
# Pi. Path is relative to the working directory the app is launched
# from.
FONT_PATH = "fonts/8x13.bdf"

# HUB75 panel geometry (hzeller rpi-rgb-led-matrix RGBMatrixOptions).
# Defaults: 64x64 logical panel from two 64x32 panels, serpentine-wired
# (chain of 2 folded by the U-mapper). Verify MATRIX_HARDWARE_MAPPING and
# MATRIX_PIXEL_MAPPER against your wiring / HAT.
MATRIX_ROWS = 32
MATRIX_COLS = 64
MATRIX_CHAIN = 2
MATRIX_PARALLEL = 1
MATRIX_HARDWARE_MAPPING = "regular"        # or "adafruit-hat", "adafruit-hat-pwm"
MATRIX_PIXEL_MAPPER = "U-mapper"           # "" for a single straight chain
MATRIX_PWM_BITS = 4
MATRIX_BRIGHTNESS = 100
MATRIX_GPIO_SLOWDOWN = 4                    # 4 is a good starting point for a Pi 4

# Append-only JSONL event log (issue #26). The renderer writes one event per
# message advance to this file; the weighted selector reads it on every
# pick to compute display-recency. The schema is exactly
# `{event_type, message_id, timestamp, sent_at}` — no favorite or other
# mutable fields. Bounded ring of the most recent N entries (default 100).
# Path is relative to the working directory the app is launched from.
EVENT_LOG_PATH = "data/events.jsonl"
EVENT_LOG_MAX_ENTRIES = 100

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL = "INFO"

# AUTO_UPDATE controls whether the Pi upgrades itself automatically.
# When true: the loader swaps to the Flask-expected SHA at boot, and
# the MQTT `check-for-update` envelope can trigger an upgrade
# mid-flight (production behavior).
# When false (default): the loader boots the existing version and
# the app ignores `check-for-update` envelopes. Safe default for
# local dev runs from a home-dir clone — a Flask deploy won't
# clobber your in-progress code. Production Pi installs should
# set this to true in the canonical settings.toml (or via the
# AUTO_UPDATE env var on the systemd unit) to preserve the
# pre-existing auto-upgrade behavior. Env var overrides this.
AUTO_UPDATE = false
