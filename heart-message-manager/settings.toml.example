# =============================================================================
# Heart Message Manager — Configuration
# =============================================================================
# Local dev: copy this file to settings.toml and fill in values.
#   cp settings.toml.example settings.toml
#
# Heroku: set these as environment variables (config vars):
#   heroku config:set AIO_USERNAME=xxx AIO_KEY=xxx AIO_MESSAGES_FEED=xxx \
#   AIO_CONFIG_FEED=xxx AWS_S3_BUCKET=xxx
#
# All keys are required unless marked [optional].
# =============================================================================

# -----------------------------------------------------------------------------
# Flask server
# -----------------------------------------------------------------------------
# Port for the Flask server.
PORT = 3100

# -----------------------------------------------------------------------------
# AWS S3 — for message logging and config snapshots
# -----------------------------------------------------------------------------
# [optional] AWS access key. Falls back to IAM role on Heroku.
AWS_ACCESS_KEY_ID = "minioadmin"
AWS_SECRET_ACCESS_KEY = "minioadmin"
AWS_S3_REGION = "us-east-1"
AWS_S3_BUCKET = "YOUR_S3_BUCKET_NAME"
# [optional] Overrride S3 endpoint for local MinIO. Defaults to AWS S3.
# AWS_S3_ENDPOINT_URL = "http://localhost:9000"

# -----------------------------------------------------------------------------
# Adafruit IO — for MQTT publishing (both REST and MQTT use the same credentials)
# -----------------------------------------------------------------------------

# MQTT client: "adafruit" (Adafruit IO MQTT with TLS) or "paho" (raw paho-mqtt, for local dev).
# Flask and subscriber use the same client.
MQTT_CLIENT = "adafruit"

# Default: io.adafruit.com (Adafruit IO cloud with TLS on port 8883).
# Local dev with Mosquitto: localhost, port 1883 (no TLS).
AIO_HOST = "io.adafruit.com"
AIO_PORT = 8883
AIO_USERNAME = "YOUR_AIO_USERNAME"
AIO_KEY = "YOUR_AIO_KEY"
AIO_MESSAGES_FEED = "YOUR_AIO_MESSAGES_FEED_NAME"
AIO_CONFIG_FEED = "YOUR_AIO_CONFIG_FEED_NAME"

# Unified MQTT feed for the new MessageManager-based publish.
AIO_FEED = "lindsay50"

# REST API URLs for seeding (Flask seeds from itself via localhost).
# On Heroku, override these via config vars with the actual public URL
# if the Flask server is behind a proxy that changes the port.
CONFIG_API_URL = "http://localhost:3100/api/config"
MESSAGES_API_URL = "http://localhost:3100/api/messages"
