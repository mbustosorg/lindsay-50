# =============================================================================
# Heart Message Manager — Configuration
# =============================================================================
# Local dev: copy this file to settings.toml and fill in values.
#   cp settings.toml.example settings.toml
#
# Heroku: set these as environment variables (config vars):
#   heroku config:set MQTT_USERNAME=xxx MQTT_PASSWORD=xxx MQTT_HOST=xxx \
#   MQTT_PORT=8883 MQTT_TOPIC=xxx AWS_S3_BUCKET=xxx
#
# All keys are required unless marked [optional].
# =============================================================================

# -----------------------------------------------------------------------------
# Flask server
# -----------------------------------------------------------------------------
# Port for the Flask server.
PORT = 3100

# -----------------------------------------------------------------------------
# Twilio — webhook authentication
# -----------------------------------------------------------------------------
# [optional] Twilio Auth Token (Console → Account Info). When set, POST
# /api/messages verifies the X-Twilio-Signature header and rejects (403) any
# request not genuinely signed by Twilio. Leave unset for local curl testing —
# the endpoint is then unauthenticated and logs a startup warning.
# TWILIO_AUTH_TOKEN = "your_twilio_auth_token"

# -----------------------------------------------------------------------------
# AWS S3 — for message logging and config snapshots
# -----------------------------------------------------------------------------
# [optional] AWS access key. Falls back to IAM role on Heroku.
AWS_ACCESS_KEY_ID = "minioadmin"
AWS_SECRET_ACCESS_KEY = "minioadmin"
AWS_S3_REGION = "us-east-1"
AWS_S3_BUCKET = "YOUR_S3_BUCKET_NAME"
# [optional] Overrride S3 endpoint for local MinIO. Defaults to AWS S3.
# AWS_S3_ENDPOINT_URL = "http://localhost:9000"

# -----------------------------------------------------------------------------
# Adafruit IO — for MQTT publishing (both REST and MQTT use the same credentials)
# -----------------------------------------------------------------------------

# Adafruit IO over MQTT.
# MQTT_HOST Default: io.adafruit.com (Adafruit IO cloud with TLS on port 8883).
#   Local dev with Mosquitto: localhost, port 1883 (no TLS).
# MQTT_USERNAME = your AIO username, MQTT_PASSWORD = your AIO key.
# MQTT_TOPIC is the full wire-format topic — paho subscribes verbatim, with
# no broker-specific translation. For Adafruit IO, that means
# "{username}/feeds/{feedname}" (e.g. "mbustosorg/feeds/lindsay50"). For
# local Mosquitto, any topic works (e.g. "lindsay50" or "test/configs").
# The Flask publisher, the Pi subscriber, and the browser SUBSCRIBE all
# use this single value.
MQTT_HOST = "io.adafruit.com"
MQTT_PORT = 8883
MQTT_USERNAME = "YOUR_AIO_USERNAME"
MQTT_PASSWORD = "YOUR_AIO_KEY"
MQTT_TOPIC = "YOUR_AIO_USERNAME/feeds/YOUR_AIO_FEED_NAME"

# Status topic — the Flask server subscribes to the same
# status topic the Pi publishes on. Empty = derive as
# "{MQTT_TOPIC}-status" (e.g. "mbustosorg/feeds/lindsay50-status").
# The env var `MQTT_STATUS_TOPIC` (if set) takes precedence over
# this value at process start. On Adafruit IO the corresponding
# feed must be created in the AIO dashboard before the Pi
# starts publishing — the broker silently rejects publishes
# to a non-existent feed.
MQTT_STATUS_TOPIC = ""

# REST API URLs for seeding (Flask seeds from itself via localhost).
# On Heroku, override these via config vars with the actual public URL
# if the Flask server is behind a proxy that changes the port.
CONFIG_API_URL = "http://localhost:3100/api/config"
MESSAGES_API_URL = "http://localhost:3100/api/messages"

# -----------------------------------------------------------------------------
# Twilio — webhook signature verification
# -----------------------------------------------------------------------------
# Your Twilio Auth Token from the Twilio console.
TWILIO_AUTH_TOKEN = "YOUR_TWILIO_AUTH_TOKEN"

# -----------------------------------------------------------------------------
# Admin authentication
# -----------------------------------------------------------------------------
[auth]
# Username and password for the browser-based admin UI login.
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD = "your-browser-password"
# API key for ESP32 machine clients (X-API-Key header auth).
API_SECRET_KEY = "your-esp32-api-key"
# Session inactivity timeout in minutes (sliding window).
ADMIN_SESSION_TIMEOUT_MINS = 60

# -----------------------------------------------------------------------------
# MQTT-over-WebSocket (browser-side)
# -----------------------------------------------------------------------------
# The browser-based admin UI subscribes to the same MQTT broker over a
# WebSocket transport (in addition to the device's native MQTT
# connection). The base template inlines the resolved values into
# `window.APP_CONFIG` and the MqttWsClient opens a WS connection from
# every admin page.
[mqtt_ws]
# Full browser-side MQTT-over-WS URL. If set, this wins outright.
# Leave unset to derive from `MQTT_HOST` + `MQTT_WS_PORT` below.
# MQTT_WS_URL = "ws://localhost:9001/mqtt"

# Port for the browser-side MQTT-over-WS connection. Default is 9001
# (the protocol default for Mosquitto) for loopback hosts and 443 for
# remote brokers. The `scripts/start-app.sh` Docker flow maps host
# 9002 → container 9001 to avoid MinIO's console on host 9001; set
# `MQTT_WS_PORT = "9002"` if you use that flow.
# NOTE: a native Mosquitto broker must be started with `--ws-port 9001`
# to expose the MQTT-over-WS transport. Example:
#   mosquitto -p 1883 --ws-port 9001
# MQTT_WS_PORT = "9001"

# How long a disconnect (in ms) is allowed to elapse before the status
# block transitions to "Paused" and a wipe + re-seed runs on reconnect.
# Default 300000 ms = 5 minutes. Lower this for tests (e.g. 30000 for
# the 30-second paused transition verification).
MQTT_LONG_DISCONNECT_MS = 300000
