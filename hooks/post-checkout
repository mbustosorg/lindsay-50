#!/bin/bash
set -euo pipefail

# Git passes these three arguments automatically
PREV_HEAD=$1
NEW_HEAD=$2
CHECKOUT_TYPE=$3

# 1. Ensure it's a branch checkout, not a file checkout (type 1 = branch, type 0 = file)
if [ "$CHECKOUT_TYPE" -ne 1 ]; then
    exit 0
fi

# 2. Check if this worktree has already been initialized
if [ -f ".git_wt_initialized" ]; then
    exit 0
fi

# 3. Detect new worktree creation
# When a worktree is created, the previous HEAD is this magic empty value
EMPTY_HASH="0000000000000000000000000000000000000000"

if [ "$PREV_HEAD" != "$EMPTY_HASH" ]; then
    # Normal branch checkout, not a new worktree
    exit 0
fi

echo "🚀 New Git worktree detected! Running one-time setup..."

# ---------------------------------------------------------------------------
# Project-specific setup — edit this section for your project
# ---------------------------------------------------------------------------

# Python venv + deps
echo "📦 Creating Python venv and installing dependencies..."
if [ ! -d ".venv" ]; then
    python3 -m venv .venv
    echo "   Created .venv"
else
    echo "   .venv already exists, skipping"
fi

# shellcheck disable=SC1091
if [ -f ".venv/bin/activate" ]; then
    . .venv/bin/activate
    pip install -q --upgrade pip
    if [ -f "requirements.txt" ]; then
        pip install -q -r requirements.txt
        echo "   Installed Python deps from requirements.txt"
    fi
    if [ -d "tests" ]; then
        pip install -q pytest
        echo "   Installed pytest"
    fi
fi

# Copy settings.toml files from the main worktree (gitignored, so not in
# repo). The actual copy logic lives in scripts/sync_settings.sh so it
# can also be run directly to refresh a clobbered settings.toml. The
# app handles creating secret_key and db.sqlite on first startup.
#
# Resolve symlinks so the script path is correct whether the hook was
# invoked via .git/hooks/post-checkout (-> hooks/post-checkout) or
# directly from hooks/post-checkout. Without this, dirname "$0" lands
# on .git/hooks and the relative path resolves to .git/scripts/...,
# which doesn't exist — and the "skipped" branch below fires silently.
HOOK_PATH="$0"
if [ -L "$HOOK_PATH" ]; then
    HOOK_PATH="$(readlink "$HOOK_PATH")"
fi
SCRIPT_DIR="$(cd "$(dirname "$HOOK_PATH")" && pwd)"
SYNC_SCRIPT="$SCRIPT_DIR/../scripts/sync_settings.sh"
if [ -f "$SYNC_SCRIPT" ]; then
    bash "$SYNC_SCRIPT"
else
    echo "⚠️  $SYNC_SCRIPT not found — settings.toml not copied" >&2
fi

# ---------------------------------------------------------------------------
# Mark this worktree as initialized — guard for future checkouts
# ---------------------------------------------------------------------------
touch ".git_wt_initialized"
echo "✨ Worktree preparation complete."
